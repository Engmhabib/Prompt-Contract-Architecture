# PCA configuration
PCA_CONTRACTS_DIR=./contracts
PCA_DATABASE_URL=postgresql+asyncpg://pca:pca@localhost:5432/pca
PCA_JWT_SECRET=change-me-in-production
PCA_JWT_ALGORITHM=HS256
PCA_ALLOW_WRITES=false
# When true, serves the playground UI at "/" and enables POST /v1/dev/token
PCA_DEV_MODE=true

# LLM (LiteLLM)
PCA_LLM_MODEL=gpt-4o-mini
# "litellm" for real providers, "mock" for deterministic local/test runs
PCA_LLM_PROVIDER=litellm
OPENAI_API_KEY=sk-...
